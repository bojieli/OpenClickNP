// PassThrough: zero-state pass-through. Smaller than `Pass`; used as a
// placeholder/registered combinational stage between named edges.
.element PassThrough <1, 1> {
    .state {}
    .init {}
    .handler {
        if (test_input_port(PORT_1)) set_output_port(1, read_input_port(PORT_1));
        return PORT_1;
    }
}
